# Plugins defined in your _config.yml
group :jekyll_plugins do
  gem "jekyll-sitemap"
  gem "jekyll-feed"
  gem "jekyll-last-modified-at"
  gem "jekyll-gist"
  gem "jekyll-paginate"
  gem "jemoji"
  gem "jekyll-include-cache"
end

